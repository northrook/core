{
  "name": "northrook/core",
  "description": "Core implementation.",
  "type": "library",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Martin Nielsen",
      "email": "mn@northrook.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Northrook\\": "src"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-curl": "*",
    "northrook/core-contracts": "dev-main"
  },
  "require-dev": {
    "northrook/php-cs": "dev-main",
    "symfony/http-foundation": "^8.1",
    "phpstan/phpstan": "^2.2",
    "phpstan/extension-installer": "^1.4",
    "tracy/tracy": "^2.12"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "phpstan": "vendor/bin/phpstan analyse"
  }
}
